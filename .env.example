# Environment Configuration

# Database (Neon Postgres)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Optional for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (Email Verification)
# Get your API key at https://resend.com
RESEND_API_KEY="re_..."

# Xendit (Invoices / checkout) — set for Production + Preview in Vercel
XENDIT_SECRET_KEY="xnd_development_..."
# Optional: verify invoice webhooks (Dashboard → Webhooks → callback token)
XENDIT_WEBHOOK_TOKEN=""
# Default checkout currency when the client does not send one (pricing page sends VND or USD).
XENDIT_DEFAULT_CURRENCY="VND"
# Convert USD list prices → VNĐ for invoices (tune to your FX policy)
XENDIT_VND_PER_USD="25000"
# Optional: IDR only if you set XENDIT_DEFAULT_CURRENCY=IDR or pass currency from a custom client
XENDIT_IDR_PER_USD="16500"

# TikTok Shop Open Connect (server only — never NEXT_PUBLIC the secret)
# App ID from Partner Center = TIKTOK_SHOP_APP_KEY (app_key)
TIKTOK_SHOP_APP_KEY=""
TIKTOK_SHOP_APP_SECRET=""
# Optional: must exactly match URL registered in TikTok Developer Console
# TIKTOK_SHOP_REDIRECT_URI="https://yourdomain.com/api/auth/tiktok/callback"

# TikTok Business / Login Kit (open.tiktokapis.com) — separate from Shop seller API
TIKTOK_BUSINESS_CLIENT_KEY=""
TIKTOK_BUSINESS_CLIENT_SECRET=""
# Optional aliases if you prefer APP_ID naming:
# TIKTOK_BUSINESS_APP_ID=""
# TIKTOK_BUSINESS_APP_SECRET=""
# Optional: override default callback (must be registered in TikTok for Developers)
# TIKTOK_BUSINESS_REDIRECT_URI="https://yourdomain.com/api/auth/tiktok-business/callback"
# Space or comma-separated scopes for authorize URL (see TikTok app settings)
# TIKTOK_BUSINESS_OAUTH_SCOPES="user.info.basic,video.list"

# Hide connectors from dashboard + block OAuth (set to "false" to disable)
# TIKTOK_SHOP_CONNECT_ENABLED="true"
# TIKTOK_BUSINESS_CONNECT_ENABLED="true"
